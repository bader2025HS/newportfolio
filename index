<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Basile Suliman | Portfolio</title>
  <link rel="stylesheet" href="style.css" />
</head>

<body>

  <nav class="nav">
    <a href="#hero" class="nav-logo">Basile Suliman</a>
    <div class="nav-links">
      <a href="#about">About</a>
      <a href="#experience">Experience</a>
      <a href="#work">Work</a>
      <a href="#contact">Contact</a>
    </div>
  </nav>

  <main>

    <section id="hero" class="section hero">
      <p class="eyebrow">Portfolio</p>
      <h1>Basile Suliman</h1>
      <p class="hero-text">
        Communication, international affairs, sustainability and storytelling.
      </p>
      <a href="#about" class="scroll-link">Scroll ↓</a>
    </section>

    <section id="about" class="section reveal">
      <div class="section-number">01</div>
      <h2>About</h2>
      <p>
        I turn complex international and sustainability topics into clear,
        engaging and accessible stories.
      </p>
    </section>

    <section id="experience" class="section reveal">
      <div class="section-number">02</div>
      <h2>Experience</h2>

      <div class="card">
        <h3>BNP Paribas</h3>
        <p>Group Communication — Content Strategy & People Engagement</p>
      </div>

      <div class="card">
        <h3>Organisation Internationale de la Francophonie</h3>
        <p>Project monitoring, country briefs and data analysis.</p>
      </div>

      <div class="card">
        <h3>AQLITY</h3>
        <p>Humanitarian data analysis and research support.</p>
      </div>
    </section>

    <section id="work" class="section reveal">
      <div class="section-number">03</div>
      <h2>Selected Work</h2>

      <div class="work-grid">
        <div class="work-card">Corporate Communication</div>
        <div class="work-card">Research Papers</div>
        <div class="work-card">Data Visualisation</div>
        <div class="work-card">Sustainability Content</div>
      </div>
    </section>

    <section id="education" class="section reveal">
      <div class="section-number">04</div>
      <h2>Education Journey</h2>
      <p>France → Japan → Germany</p>
    </section>

    <section id="contact" class="section reveal contact">
      <div class="section-number">05</div>
      <h2>Let’s connect.</h2>
      <a href="mailto:your-email@example.com">Email me</a>
    </section>

  </main>

  <script src="script.js"></script>
</body>
</html>

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: Arial, sans-serif;
  background: #f6f3ee;
  color: #111;
}

.nav {
  position: fixed;
  top: 24px;
  left: 50%;
  transform: translateX(-50%);
  width: calc(100% - 48px);
  max-width: 1200px;
  z-index: 100;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 18px;
  border: 1px solid #111;
  border-radius: 999px;
  background: rgba(246, 243, 238, 0.85);
  backdrop-filter: blur(12px);
}

.nav a {
  color: #111;
  text-decoration: none;
  font-size: 14px;
}

.nav-logo {
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.nav-links {
  display: flex;
  gap: 20px;
}

.section {
  min-height: 100vh;
  padding: 140px 8vw 80px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero h1 {
  font-size: clamp(64px, 12vw, 160px);
  line-height: 0.9;
  letter-spacing: -0.07em;
  max-width: 1000px;
}

.eyebrow,
.section-number {
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  margin-bottom: 24px;
  opacity: 0.6;
}

.hero-text {
  margin-top: 32px;
  font-size: clamp(24px, 4vw, 48px);
  max-width: 800px;
  line-height: 1.1;
}

.scroll-link {
  margin-top: 60px;
  color: #111;
  text-decoration: none;
  font-size: 18px;
}

h2 {
  font-size: clamp(52px, 9vw, 120px);
  letter-spacing: -0.06em;
  line-height: 0.9;
  margin-bottom: 40px;
}

section p {
  font-size: clamp(22px, 3vw, 42px);
  line-height: 1.2;
  max-width: 900px;
}

.card {
  border-top: 1px solid #111;
  padding: 28px 0;
  max-width: 900px;
}

.card h3 {
  font-size: clamp(28px, 4vw, 56px);
  letter-spacing: -0.04em;
}

.card p {
  font-size: 20px;
  margin-top: 8px;
  opacity: 0.75;
}

.work-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
  max-width: 1000px;
}

.work-card {
  min-height: 220px;
  border: 1px solid #111;
  border-radius: 28px;
  padding: 28px;
  font-size: 28px;
  display: flex;
  align-items: flex-end;
  transition: 0.3s ease;
}

.work-card:hover {
  background: #111;
  color: #f6f3ee;
}

.contact a {
  font-size: 32px;
  color: #111;
  text-decoration: none;
  border-bottom: 2px solid #111;
  width: fit-content;
}

.reveal {
  opacity: 0;
  transform: translateY(60px);
  transition: 0.9s ease;
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

@media (max-width: 700px) {
  .nav-links {
    display: none;
  }

  .section {
    padding: 120px 24px 60px;
  }

  .work-grid {
    grid-template-columns: 1fr;
  }
}
